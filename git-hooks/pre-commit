#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RUN_NODE_TOOL="$ROOT_DIR/scripts/pre-commit/run-node-tool.sh"
FILTER_FILES="$ROOT_DIR/scripts/pre-commit/filter-staged-files.mjs"
WORKTREE_GUARDS="$ROOT_DIR/scripts/lib/worktree-guards.sh"

if [[ ! -x "$RUN_NODE_TOOL" ]]; then
  echo "Missing helper: $RUN_NODE_TOOL" >&2
  exit 1
fi

if [[ ! -f "$FILTER_FILES" ]]; then
  echo "Missing helper: $FILTER_FILES" >&2
  exit 1
fi

if [[ -f "$WORKTREE_GUARDS" ]]; then
  # Sacred home clones are runtime anchors, not coding surfaces. Block any
  # commit attempt from those checkouts unless the operator explicitly enters a
  # break-glass hotfix path on the base branch.
  # shellcheck source=scripts/lib/worktree-guards.sh
  source "$WORKTREE_GUARDS"
  worktree_guard_forbid_sacred_home_commit "$ROOT_DIR"
  # Protected base branches stay pull-only everywhere else, even after sacred
  # home clone enforcement routes normal implementation work into temp lanes.
  worktree_guard_forbid_protected_base_branch_commit "$ROOT_DIR"
  # Durable main/consumer lanes must not commit from stale branch truth. The
  # legacy wrappers fetch+fast-forward these lanes; this hook still stops old
  # durable-lane commits from sneaking in after the branch falls behind origin.
  worktree_guard_forbid_stale_durable_lane_commit "$ROOT_DIR"
fi

# Security: avoid option-injection from malicious file names (e.g. "--all", "--force").
# Robustness: NUL-delimited file list handles spaces/newlines safely.
# Compatibility: use read loops instead of `mapfile` so this runs on macOS Bash 3.x.
files=()
while IFS= read -r -d '' file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

lint_files=()
while IFS= read -r -d '' file; do
  lint_files+=("$file")
done < <(node "$FILTER_FILES" lint -- "${files[@]}")

format_files=()
while IFS= read -r -d '' file; do
  format_files+=("$file")
done < <(node "$FILTER_FILES" format -- "${files[@]}")

if [ "${#lint_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxlint --type-aware --fix -- "${lint_files[@]}"
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  "$RUN_NODE_TOOL" oxfmt --write --no-error-on-unmatched-pattern "${format_files[@]}"
fi

git add -- "${files[@]}"
